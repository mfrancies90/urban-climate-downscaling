                    })

                except Exception as e:
                    nan_count += 1
                    continue

    if nan_count > 0:
        print(f"Warning: {nan_count} validation batches skipped due to numerical issues")

    return total_val_loss / max(len(val_loader) - nan_count, 1)

def evaluate_model_comprehensive(model, val_loader, climate_dataset, device, graph_data):
    """Comprehensive model evaluation with multiple metrics."""
    model.eval()

    all_predictions = []
    all_targets = []
    temp_mean = climate_dataset.mean[0].item()  # t2m mean
    temp_std = climate_dataset.std[0].item()    # t2m std

    print("Running comprehensive evaluation...")

    with torch.no_grad():
        for node_features, targets in tqdm(val_loader, desc="Evaluating"):
            try:
                graph_data.x = node_features.squeeze(0).to(device)
                pred_norm = model(graph_data)

                # Denormalize predictions and targets
                pred_denorm = pred_norm.cpu() * temp_std + temp_mean
                target_denorm = targets.squeeze(0) * temp_std + temp_mean

                all_predictions.append(pred_denorm)
                all_targets.append(target_denorm)
            except:
                continue

    # Concatenate all predictions and targets
    predictions = torch.cat(all_predictions)
    targets = torch.cat(all_targets)

    # Compute metrics
    mse = torch.mean((predictions - targets)**2)
    rmse = torch.sqrt(mse)
    mae = torch.mean(torch.abs(predictions - targets))

    print(f"\n=== EVALUATION RESULTS ===")
    print(f"RMSE: {rmse:.4f} K")
    print(f"MAE:  {mae:.4f} K")
    print(f"Samples evaluated: {len(predictions)}")

    return predictions, targets, rmse.item(), mae.item()

def benchmark_inference_speed(model, val_loader, device, graph_data, num_samples=100):
    """Detailed inference speed benchmarking."""
    print(f"Benchmarking inference speed on {num_samples} samples...")

    model.eval()

    data_loading_times = []
    model_inference_times = []
    total_times = []

    sample_count = 0

    for node_features, targets in val_loader:
        if sample_count >= num_samples:
            break

        # Measure data loading/preprocessing time
        data_start = time.time()
        graph_data.x = node_features.squeeze(0).to(device)
        if device.type == 'cuda':
            torch.cuda.synchronize()
        data_time = time.time() - data_start
        data_loading_times.append(data_time)

        # Measure pure model inference time
        if device.type == 'cuda':
            torch.cuda.synchronize()
        inference_start = time.time()

        with torch.no_grad():
            output = model(graph_data)

        if device.type == 'cuda':
            torch.cuda.synchronize()
        inference_time = time.time() - inference_start
        model_inference_times.append(inference_time)

        total_times.append(data_time + inference_time)
        sample_count += 1

    # Calculate statistics
    stats = {
        'avg_data_loading_ms': np.mean(data_loading_times) * 1000,
        'avg_model_inference_ms': np.mean(model_inference_times) * 1000,
        'avg_total_time_ms': np.mean(total_times) * 1000,
        'std_inference_ms': np.std(model_inference_times) * 1000,
        'min_inference_ms': np.min(model_inference_times) * 1000,
        'max_inference_ms': np.max(model_inference_times) * 1000,
        'throughput_samples_per_sec': 1.0 / np.mean(total_times),
        'model_only_throughput': 1.0 / np.mean(model_inference_times)
    }

    return stats, model_inference_times  


