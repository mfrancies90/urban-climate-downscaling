class PerformanceMonitor:
    """Comprehensive performance monitoring for training time, memory usage, and inference speed."""
    def __init__(self, device):
        self.device = device
        self.is_cuda = device.type == 'cuda'
        self.reset()

    def reset(self):
        self.training_times = []
        self.validation_times = []
        self.memory_usage = []
        self.gpu_memory_usage = []
        self.inference_times = []
        self.total_training_time = 0
        self.peak_memory = 0
        self.peak_gpu_memory = 0

    def get_memory_usage(self):
        process = psutil.Process()
        cpu_memory = process.memory_info().rss / 1024 / 1024  # MB
        gpu_memory = 0
        if self.is_cuda and torch.cuda.is_available():
            gpu_memory = torch.cuda.memory_allocated() / 1024 / 1024  # MB
        return cpu_memory, gpu_memory

    @contextmanager
    def measure_time(self, operation_type='training'):
        if self.is_cuda:
            torch.cuda.synchronize()
        start_time = time.time()
        cpu_mem_start, gpu_mem_start = self.get_memory_usage()

        try:
            yield
        finally:
            if self.is_cuda:
                torch.cuda.synchronize()
            end_time = time.time()
            cpu_mem_end, gpu_mem_end = self.get_memory_usage()
            elapsed_time = end_time - start_time

            if operation_type == 'training':
                self.training_times.append(elapsed_time)
            elif operation_type == 'validation':
                self.validation_times.append(elapsed_time)
            elif operation_type == 'inference':
                self.inference_times.append(elapsed_time)

            self.memory_usage.append(cpu_mem_end)
            self.gpu_memory_usage.append(gpu_mem_end)
            self.peak_memory = max(self.peak_memory, cpu_mem_end)
            self.peak_gpu_memory = max(self.peak_gpu_memory, gpu_mem_end)

    def get_summary(self):
        summary = {
            'total_training_time_minutes': sum(self.training_times) / 60,
            'avg_epoch_time_seconds': np.mean(self.training_times) if self.training_times else 0,
            'avg_validation_time_seconds': np.mean(self.validation_times) if self.validation_times else 0,
            'avg_inference_time_ms': np.mean(self.inference_times) * 1000 if self.inference_times else 0,
            'peak_cpu_memory_mb': self.peak_memory,
            'peak_gpu_memory_mb': self.peak_gpu_memory,
            'avg_cpu_memory_mb': np.mean(self.memory_usage) if self.memory_usage else 0,
            'avg_gpu_memory_mb': np.mean(self.gpu_memory_usage) if self.gpu_memory_usage else 0,
        }
        if self.training_times:
            summary['training_throughput_samples_per_sec'] = 1.0 / np.mean(self.training_times)
        if self.inference_times:
            summary['inference_throughput_samples_per_sec'] = 1.0 / np.mean(self.inference_times)
        return summary

class ClimateDataset(Dataset):
    def __init__(self, nc_file_path, variables, n_timesteps_in=1, n_timesteps_out=1):
        super().__init__()
        self.ds = xr.open_dataset(nc_file_path)
        self.data = self.ds[variables].to_array(dim='channel').transpose('valid_time', 'channel', 'latitude', 'longitude')
        self.mean = self.data.mean(dim=('valid_time', 'latitude', 'longitude')).compute()
        self.std = self.data.std(dim=('valid_time', 'latitude', 'longitude')).compute()
        self.data = (self.data - self.mean) / self.std
        self.n_timesteps_in, self.n_timesteps_out, self.total_timesteps = n_timesteps_in, n_timesteps_out, len(self.data.valid_time)

    def __len__(self):
        return self.total_timesteps - (self.n_timesteps_in + self.n_timesteps_out) + 1

    def __getitem__(self, idx):
        start, mid, end = idx, idx + self.n_timesteps_in, idx + self.n_timesteps_in + self.n_timesteps_out
        X = torch.from_numpy(self.data.isel(valid_time=slice(start, mid))[0].values).float()
        Y = torch.from_numpy(self.data.isel(valid_time=slice(mid, end))[0].values).float()
        return X, Y

class SimpleGFNO(nn.Module):
    def __init__(self, in_channels, out_channels, num_modes, U, U_T):
        super().__init__()
        self.register_buffer('U', U)
        self.register_buffer('U_T', U_T)
        self.num_modes = num_modes
        self.in_channels = in_channels
        self.out_channels = out_channels
        self.spectral_kernel = nn.Linear(self.in_channels, self.out_channels)

    def forward(self, graph):
        x = graph.x
        x_hat = torch.matmul(self.U_T, x)
        modes = x_hat[:self.num_modes, :]
        filtered = self.spectral_kernel(modes)
        out_hat = torch.zeros(x.shape[0], self.out_channels, device=x.device, dtype=x.dtype)
        out_hat[:self.num_modes, :] = filtered
        return torch.matmul(self.U, out_hat)

class GFNODataset(Dataset):
    def __init__(self, c_data, s_model, ndvi_map, device):
        self.c, self.s, self.n, self.d = c_data, s_model, ndvi_map.to(device), device
        self.H, self.W = ndvi_map.shape[0], ndvi_map.shape[1]

    def __len__(self):
        return len(self.c)

    @torch.no_grad()
    def __getitem__(self, idx):
        cX, cY = self.c[idx]
        cX = cX.unsqueeze(0).to(self.d)
        cor, _ = self.s(cX)
        cor_flat = cor.squeeze(0).permute(1, 2, 0).reshape(-1, self.c.data.shape[1])
        n_flat = self.n.reshape(-1, 1)
        node_f = torch.cat([cor_flat, n_flat], dim=-1)
        target = cY[0].reshape(-1, 1)
        return node_f.cpu(), target.cpu()

