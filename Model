def train_epoch_enhanced(model, train_loader, optimizer, loss_fn, device, monitor, graph_data):
    """Enhanced training epoch with comprehensive monitoring."""
    model.train()
    total_train_loss = 0
    nan_count = 0

    with monitor.measure_time('training'):
        train_bar = tqdm(train_loader, desc="Training", leave=False)

        for node_features, target_temp in train_bar:
            try:
                # Memory cleanup
                if device.type == 'cuda':
                    torch.cuda.empty_cache()

                graph_data.x = node_features.squeeze(0).to(device)
                targets = target_temp.squeeze(0).to(device)

                # Check for NaN inputs
                if torch.isnan(graph_data.x).any() or torch.isnan(targets).any():
                    nan_count += 1
                    continue

                optimizer.zero_grad()
                prediction = model(graph_data)

                # Check for NaN predictions
                if torch.isnan(prediction).any():
                    nan_count += 1
                    continue

                loss = loss_fn(prediction, targets)

                # Check for NaN loss
                if torch.isnan(loss) or torch.isinf(loss):
                    nan_count += 1
                    continue

                loss.backward()

                # Gradient clipping for stability
                torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)

                optimizer.step()
                total_train_loss += loss.item()

                # Update progress bar with memory info
                cpu_mem, gpu_mem = monitor.get_memory_usage()
                train_bar.set_postfix({
                    'loss': f'{loss.item():.6f}',
                    'mem': f'{cpu_mem:.0f}MB',
                    'gpu': f'{gpu_mem:.0f}MB' if gpu_mem > 0 else 'N/A',
                    'nan_batches': nan_count
                })

            except Exception as e:
                print(f"Error in training batch: {e}")
                nan_count += 1
                continue

    if nan_count > 0:
        print(f"Warning: {nan_count} training batches skipped due to numerical issues")

    return total_train_loss / max(len(train_loader) - nan_count, 1)

def validate_epoch_enhanced(model, val_loader, loss_fn, device, monitor, graph_data):
    """Enhanced validation epoch with comprehensive monitoring."""
    model.eval()
    total_val_loss = 0
    nan_count = 0

    with monitor.measure_time('validation'):
        with torch.no_grad():
            val_bar = tqdm(val_loader, desc="Validation", leave=False)

            for node_features, target_temp in val_bar:
                try:
                    graph_data.x = node_features.squeeze(0).to(device)
